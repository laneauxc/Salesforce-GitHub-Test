---
/**
 * Agent Builder Page
 * Form interface for creating and configuring AI agents using HeroUI components
 */
import Layout from '../../layouts/Layout.astro';
import AgentBuilderForm from '../../components/AgentBuilderForm';
---

<Layout 
  title="Agent Builder" 
  description="Create and configure AI agents with custom instructions and tools"
>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold">Agent Builder</h1>
      <p class="text-gray-600 mt-2">Configure your AI agent with custom settings and capabilities</p>
    </div>

    <!-- Agent Builder Form Component with HeroUI -->
    <AgentBuilderForm client:visible />
  </div>
</Layout>
