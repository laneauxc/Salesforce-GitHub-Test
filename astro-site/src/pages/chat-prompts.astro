---
import SidebarNav from '../components/SidebarNav';
import ChatInterface from '../components/ChatInterface';
import ProfileMenu from '../components/ProfileMenu';
import OnboardingTour from '../components/OnboardingTour';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const navSections = [
  {
    header: 'Create',
    items: [
      { icon: 'chat', label: 'Chat', selected: true, href: `${baseUrl}chat-prompts/` },
      { icon: 'agent-builder', label: 'Agent Builder', href: `${baseUrl}agent-builder/` },
      { icon: 'audio', label: 'Audio', href: `${baseUrl}audio/` },
      { icon: 'images', label: 'Images', href: `${baseUrl}images/` },
      { icon: 'videos', label: 'Videos', href: `${baseUrl}videos/` },
      { icon: 'assistants', label: 'Assistants', href: `${baseUrl}assistants/` },
    ],
  },
  {
    header: 'Manage',
    items: [
      { icon: 'usage', label: 'Usage', href: `${baseUrl}usage/` },
      { icon: 'api-keys', label: 'API keys', href: `${baseUrl}api-keys/` },
      { icon: 'apps', label: 'Apps', href: `${baseUrl}apps/` },
      { icon: 'logs', label: 'Logs', href: `${baseUrl}logs/` },
      { icon: 'storage', label: 'Storage', href: `${baseUrl}storage/` },
      { icon: 'batches', label: 'Batches', href: `${baseUrl}batches/` },
    ],
  },
  {
    header: 'Optimize',
    items: [
      { icon: 'evaluation', label: 'Evaluation', href: `${baseUrl}evaluation/` },
      { icon: 'fine-tuning', label: 'Fine-tuning', href: `${baseUrl}fine-tuning/` },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Chat Prompt</title>
    <script src={`${baseUrl}dark-mode-init.js`}></script>
    <style>
      /* Smooth transition for dark mode */
      * {
        transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
      }
    </style>
  </head>
  <body class="bg-white dark:bg-gray-900">
    <div class="flex h-screen">
      <!-- Sidebar -->
      <SidebarNav 
        client:load 
        sections={navSections}
      />

      <!-- Main content area -->
      <main class="flex-1 flex flex-col relative">
        <!-- Profile Menu in top right -->
        <div class="absolute top-4 right-4 z-10">
          <ProfileMenu client:load baseUrl={baseUrl} />
        </div>
        
        <ChatInterface 
          client:load
          onCreateAgentClick={() => {
            window.location.href = `${baseUrl}agent-builder/`;
          }}
        />

        <!-- Onboarding Tour -->
        <OnboardingTour
          client:load
          storageKey="chatPromptsOnboardingCompleted"
          steps={[
            {
              title: "Welcome to Chat Prompts! 👋",
              description: "This quick tour will walk you through the key features of the Chat Prompts page. You'll learn how to select a model, use an assistant, send messages, and create your own agent. Click Next to get started!",
            },
            {
              target: "[data-tour='model-selector']",
              title: "Choose Your AI Model",
              description: "Select the AI model you want to chat with. Options include GPT-4, GPT-4 Turbo, GPT-3.5 Turbo, Claude 3 Opus, and more. Different models have different capabilities and speeds.",
              placement: "bottom",
              actionHint: "Try clicking the dropdown to explore the available models.",
            },
            {
              target: "[data-tour='assistant-selector']",
              title: "Select an Assistant",
              description: "Optionally attach a pre-configured assistant to your chat. Assistants can have custom instructions, knowledge, and behaviors. Choose 'None (Direct)' to chat directly with the selected model.",
              placement: "bottom",
              actionHint: "Try selecting an assistant from the dropdown to use its specialized capabilities.",
            },
            {
              target: "[data-tour='message-input']",
              title: "Type Your Message",
              description: "This is the main input area where you type your prompts or questions. Press Enter or click the send arrow to submit. Use Shift+Enter for a new line.",
              placement: "top",
              actionHint: "Try typing a message like 'Help me plan a trip to Paris'.",
            },
            {
              target: "[data-tour='suggestions']",
              title: "Quick-Start Suggestions",
              description: "Click any suggestion chip to instantly fill the input with a pre-written prompt. These are great starting points for common tasks like trip planning, image generation, code debugging, and more.",
              placement: "top",
              actionHint: "Click one of the suggestion chips to pre-fill your message.",
            },
            {
              target: "[data-tour='create-button']",
              title: "Create an Agent",
              description: "Ready to build your own custom AI agent? Click the + Create button to open the Agent Builder, where you can visually design a workflow using nodes and edges to automate complex tasks.",
              placement: "bottom",
              actionHint: "Click '+ Create' to open the Agent Builder and start building your first agent!",
            },
          ]}
        />
      </main>
    </div>
    
    <script>
      // Listen for dark mode changes
      window.addEventListener('darkModeChange', (e: CustomEvent<{ darkMode: boolean }>) => {
        if (e.detail.darkMode) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      });
    </script>
  </body>
</html>
